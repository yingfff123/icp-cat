{
  "manifest_version": 3,
  "name": "ICP资产提取器",
  "version": "2.0.0",
  "description": "拦截工信部备案查询响应，提取域名、IP、App/小程序。",
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://beian.miit.gov.cn/*",
    "https://hlwicpfwc.miit.gov.cn/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://beian.miit.gov.cn/*"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["injected.js"],
      "matches": ["https://beian.miit.gov.cn/*"]
    }
  ],
  "action": {
    "default_title": "ICP资产提取器",
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "16.png"
  }
}
